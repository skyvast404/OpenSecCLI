{
  "name": "openseccli",
  "version": "0.5.0",
  "description": "The open-source security CLI hub — query, enrich, automate.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "dist/main.js",
  "bin": {
    "opensec": "dist/main.js"
  },
  "exports": {
    ".": "./dist/main.js",
    "./registry": "./dist/registry-api.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "security",
    "cli",
    "pentest",
    "threat-intelligence",
    "sast",
    "vulnerability-scanner"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/user/OpenSecCLI.git"
  },
  "homepage": "https://github.com/user/OpenSecCLI#readme",
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "npm run clean-dist && tsc && npm run copy-yaml && npm run build-manifest",
    "build-manifest": "node dist/build-manifest.js",
    "clean-dist": "node scripts/clean-dist.cjs",
    "copy-yaml": "node scripts/copy-yaml.cjs",
    "start": "node dist/main.js",
    "postinstall": "node scripts/postinstall.js || true",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run --project unit",
    "test:adapter": "vitest run --project adapter",
    "test:all": "vitest run",
    "test:e2e": "vitest run --project e2e",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0"
  }
}
